NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anúncios (Google AdSense) — opcionais, sem eles o app mostra um placeholder no lugar do anúncio
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_ID=xxxxxxxxxx

# Webhook do Kiwify (só servidor, nunca exposto ao navegador)
KIWIFY_WEBHOOK_SECRET=your-kiwify-webhook-secret

# Supabase secret key (só servidor — usada para localizar o usuário pelo e-mail no webhook)
SUPABASE_SECRET_KEY=your-supabase-secret-key
